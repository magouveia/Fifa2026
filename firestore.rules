
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Dados Mestres (Convocados, Calendário Oficial)
    // Todos podem ler. Apenas o Admin pode escrever.
    match /public/mundial_data {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'magouveia1982@gmail.com';
    }

    // Dados de Simulação do Utilizador
    // Cada um só mexe no seu.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
